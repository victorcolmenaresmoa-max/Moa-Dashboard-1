# ─── Google OAuth 2.0 ────────────────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs must include:
#   https://your-project.vercel.app/api/auth/callback  (production)
#   http://localhost:3000/api/auth/callback             (local dev)

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Your production Vercel URL (no trailing slash)
NEXT_PUBLIC_BASE_URL=https://your-project.vercel.app

# Optional: restrict login to your Google Workspace domain (e.g. moaeducation.com)
# Leave empty to allow any Google account.
GOOGLE_ALLOWED_DOMAIN=moaeducation.com

# ─── Session ─────────────────────────────────────────────────────────────────
# A random 32+ character secret used to sign session cookies.
# Generate one with: openssl rand -base64 32
SESSION_SECRET=replace-with-a-long-random-secret

# ─── Google Sheets through Apps Script ───────────────────────────────────────
# Replace SheetDB with your own Google Apps Script Web App URL.
# Deploy the Apps Script as a Web App and paste its /exec URL here.
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Shared secret between Vercel and Apps Script.
# Use the same value in Apps Script Script Properties as MOA_DASHBOARD_TOKEN.
# Generate one with: openssl rand -base64 32
GOOGLE_APPS_SCRIPT_TOKEN=replace-with-a-long-random-token

# ─── RBAC — Team Access List ──────────────────────────────────────────────────
# Comma-separated list of Google Workspace emails.
# Emails not in either list will be denied access.

# Admins: full edit access + exclusive rights over Calidad=Revisado y Deadlines
ADMIN_EMAILS=victor.colmenares@moaeducation.com,luis.sumoza@moaeducation.com

# Specialists: can edit their own note column + Estado on their own tasks
SPECIALIST_EMAILS=roxangel.rodriguez@moaeducation.com,ailil.coutinho@moaeducation.com,norilys.cermeno@moaeducation.com,veronica.gonzales@moaeducation.com,melisa.espinal@moaeducation.com,noryley.suescun@moaeducation.com,ninfa.vivas@moaeducation.com,asdrubal.marquez@moaeducation.com
