{
  "version": 2,
  "buildCommand": "echo 'No build step required'",
  "outputDirectory": "public",
  "functions": {
    "api/**/*.js": {
      "runtime": "@vercel/node@3"
    }
  },
  "rewrites": [
    { "source": "/api/auth/login",    "destination": "/api/auth/login" },
    { "source": "/api/auth/callback", "destination": "/api/auth/callback" },
    { "source": "/api/auth/logout",   "destination": "/api/auth/logout" },
    { "source": "/api/auth/me",       "destination": "/api/auth/me" },
    { "source": "/api/data",          "destination": "/api/data/index" },
    { "source": "/api/data/create",   "destination": "/api/data/create" },
    { "source": "/api/data/update",   "destination": "/api/data/update" },
    { "source": "/api/data/delete",   "destination": "/api/data/delete" },
    { "source": "/(.*)",              "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
