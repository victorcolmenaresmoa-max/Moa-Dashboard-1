{
  "version": 2,
  "buildCommand": "echo 'static'",
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/api/auth/login",    "destination": "/api/auth/login.js" },
    { "source": "/api/auth/callback", "destination": "/api/auth/callback.js" },
    { "source": "/api/auth/logout",   "destination": "/api/auth/logout.js" },
    { "source": "/api/auth/me",       "destination": "/api/auth/me.js" },
    { "source": "/api/data",          "destination": "/api/data/index.js" },
    { "source": "/api/data/create",   "destination": "/api/data/create.js" },
    { "source": "/api/data/update",   "destination": "/api/data/update.js" },
    { "source": "/api/data/delete",   "destination": "/api/data/delete.js" },
    { "source": "/((?!api/).*)",      "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
